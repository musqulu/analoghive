# Copy to `.env.local` and fill in values. Never commit `.env.local`.

# Direct connection (db.*.supabase.co). Often requires IPv6; use pooler on IPv4-only networks.
# Password must be URL-encoded (e.g. `+` → `%2B`, `#` → `%23`, `?` → `%3F`, `<` → `%3C`, `[` → `%5B`).
# DATABASE_URL="postgresql://postgres:YOUR_ENCODED_PASSWORD@db.axnzmokvzdogjftvoslf.supabase.co:5432/postgres"

# Session pooler (recommended on IPv4): copy the exact URI from the Supabase dashboard
# (Database → Connection string → Session mode). It uses *.pooler.supabase.com and includes your region.
# DATABASE_URL="postgresql://postgres.axnzmokvzdogjftvoslf:YOUR_ENCODED_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

DATABASE_URL=

# Supabase Auth (Project Settings → API). Never commit real keys.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical site URL (HTTPS, no trailing slash). Never set this to http://localhost on Vercel — it forces redirects to localhost.
# Omit it on Vercel unless you need an explicit production/custom-domain URL (OAuth uses the live browser URL when unset).
# — When set on Vercel: use https://YOUR_DEPLOYMENT.vercel.app or your real domain (same as Supabase Site URL).
# — Supabase → Authentication → URL Configuration: Redirect URLs should include:
#     http://localhost:3000/auth/callback , http://localhost:3000/**
#     https://YOUR_DEPLOYMENT.vercel.app/auth/callback , optionally https://*.vercel.app/**
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# For immediate post-signup access: in Supabase Dashboard go to Authentication → Providers → Email
# and turn OFF "Confirm email" (require confirmation before sign-in). You can still send a
# verification email; the app shows a banner until the user verifies (see NEXT_PUBLIC_EMAIL_VERIFY_GRACE_DAYS).

# Days shown in the unverified-email banner copy (policy reminder only; no auto-delete in app).
# NEXT_PUBLIC_EMAIL_VERIFY_GRACE_DAYS=3

# Replicate API token for the AI chat assistant (server-only). Create one at https://replicate.com/account/api-tokens
# Used by /api/chat to stream Claude 4.5 Sonnet via the `replicate` Node SDK.
REPLICATE_API_TOKEN=
